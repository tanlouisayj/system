' ---- UPDATE FORMULAS IN CH AND CI COLUMNS ----
    Dim wsSheet As Worksheet
    Dim cell As Range
    Dim oldPrefix As String
    Dim newPrefix As String
    Dim searchRange As Range
    
    ' Define the new prefix from CH18
    newPrefix = yearVal & monthVal  ' e.g. "202603"
    
    ' Loop through all sheets to find and replace old YYYYMM prefix
    For Each wsSheet In ThisWorkbook.Sheets
        ' Search only in CH and CI columns
        Set searchRange = wsSheet.Range("CH:CI")
        
        For Each cell In searchRange.SpecialCells(xlCellTypeFormulas)
            If InStr(cell.Formula, "_Regional IBG Staff Role Tagging.xlsx") > 0 Then
                ' Extract old YYYYMM (6 digits before the underscore)
                Dim cellFormula As String
                cellFormula = cell.Formula
                
                Dim pos As Long
                pos = InStr(cellFormula, "_Regional IBG Staff Role Tagging.xlsx")
                
                If pos > 6 Then
                    oldPrefix = Mid(cellFormula, pos - 6, 6)
                    ' Only replace if it looks like a YYYYMM (all digits)
                    If IsNumeric(oldPrefix) Then
                        cell.Formula = Replace(cellFormula, oldPrefix, newPrefix)
                    End If
                End If
            End If
        Next cell
    Next wsSheet
