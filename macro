Sub RefreshIBGHeadcountByMonth()

    Dim wsProductivity As Worksheet
    Dim wsSheet As Worksheet
    Dim yearVal As String
    Dim monthVal As String
    Dim fileName As String
    Dim filePath As String
    Dim fullPath As String
    Dim wbSource As Workbook
    Dim monthCell As Range
    Dim targetCol As Long
    Dim templateCol As Long
    Dim alreadyOpen As Boolean
    Dim wb As Workbook
    Dim userInput As String
    Dim cell As Range
    Dim lastRow As Long
    Dim newPrefix As String
    Dim oldPrefix As String
    Dim r As Long
    Dim templateCell As Range
    Dim targetCell As Range
    Dim cellFormula As String
    Dim pos As Long
    Dim colOffset As Long

    ' ---- SETTINGS ----
    Set wsProductivity = ThisWorkbook.Sheets("Productivity")
    templateCol = wsProductivity.Range("CH1").Column  ' CH is master template column

    ' ---- ASK USER WHICH COLUMN TO UPDATE ----
    userInput = InputBox("Enter the column letter to update (e.g. CI, CJ, CK):" & vbNewLine & vbNewLine & _
                         "Note: CH is the template column and cannot be overwritten.", _
                         "Which Column To Update?")

    ' User cancelled
    If userInput = "" Then
        MsgBox "No column entered. Macro cancelled.", vbExclamation, "Cancelled"
        Exit Sub
    End If

    ' Convert input to uppercase and trim spaces
    userInput = UCase(Trim(userInput))

    ' Validate it's a valid column
    On Error Resume Next
    targetCol = wsProductivity.Range(userInput & "1").Column
    On Error GoTo 0

    If targetCol = 0 Then
        MsgBox "'" & userInput & "' is not a valid column. Please enter a valid column letter (e.g. CI, CJ).", _
               vbExclamation, "Invalid Column"
        Exit Sub
    End If

    ' Prevent overwriting template column CH
    If targetCol = templateCol Then
        MsgBox "Column CH is the template column and cannot be overwritten.", _
               vbExclamation, "Invalid Column"
        Exit Sub
    End If

    ' ---- READ DATE FROM ROW 18 OF TARGET COLUMN ----
    Set monthCell = wsProductivity.Cells(18, targetCol)

    If Not IsDate(monthCell.Value) Then
        MsgBox "Row 18 of column " & userInput & " does not contain a valid date. Please check.", _
               vbExclamation, "Invalid Date"
        Exit Sub
    End If

    ' Build YYYYMM from target column's row 18
    yearVal = Format(monthCell.Value, "YYYY")
    monthVal = Format(monthCell.Value, "MM")

    ' ---- CONFIRM WITH USER BEFORE PROCEEDING ----
    Dim confirm As Integer
    confirm = MsgBox("About to update column " & userInput & " using date: " & monthVal & "/" & yearVal & vbNewLine & vbNewLine & _
                     "File: " & yearVal & monthVal & "_Regional IBG Staff Role Tagging.xlsx" & vbNewLine & _
                     "Folder: \IBG Headcount\" & yearVal & "\" & vbNewLine & vbNewLine & _
                     "Proceed?", vbYesNo + vbQuestion, "Confirm Update")

    If confirm = vbNo Then
        MsgBox "Macro cancelled.", vbInformation, "Cancelled"
        Exit Sub
    End If

    ' ---- BUILD FILE PATH ----
    fileName = yearVal & monthVal & "_Regional IBG Staff Role Tagging.xlsx"
    filePath = "\\nassgdce1bvc1\IBG_Reg1&2_Vol1\IBG Reg 1&2\Qlikview\IBG Headcount\" & yearVal & "\"
    fullPath = filePath & fileName

    ' ---- CHECK FILE EXISTS ----
    If Dir(fullPath) = "" Then
        MsgBox "File not found: " & fullPath & vbNewLine & vbNewLine & _
               "Please check the file exists and network drive is accessible.", _
               vbExclamation, "File Missing"
        Exit Sub
    End If

    Application.ScreenUpdating = False
    Application.DisplayAlerts = False

    ' ---- COPY FORMULAS FROM CH (TEMPLATE) TO TARGET COLUMN ----
    lastRow = wsProductivity.Cells(wsProductivity.Rows.Count, templateCol).End(xlUp).Row
    newPrefix = yearVal & monthVal  ' e.g. "202603"
    colOffset = targetCol - templateCol  ' How many columns away from CH

    For r = 1 To lastRow
        Set templateCell = wsProductivity.Cells(r, templateCol)
        Set targetCell = wsProductivity.Cells(r, targetCol)

        If templateCell.HasFormula Then
            cellFormula = templateCell.Formula

            ' ---- CASE 1: File reference formula (COUNTIFS etc) ----
            ' Manually replace YYYYMM prefix so it points to correct file
            If InStr(cellFormula, "_Regional IBG Staff Role Tagging.xlsx") > 0 Then
                pos = InStr(cellFormula, "_Regional IBG Staff Role Tagging.xlsx")
                If pos > 6 Then
                    oldPrefix = Mid(cellFormula, pos - 6, 6)
                    If IsNumeric(oldPrefix) Then
                        cellFormula = Replace(cellFormula, oldPrefix, newPrefix)
                    End If
                End If
                targetCell.Formula = cellFormula

            ' ---- CASE 2: SUM or other formulas referencing own column ----
            ' Use Copy + PasteSpecial so Excel automatically shifts column references
            Else
                templateCell.Copy
                targetCell.PasteSpecial Paste:=xlPasteFormulas
                Application.CutCopyMode = False
            End If

        ' ---- CASE 3: Non-formula values (labels, headers) ----
        ElseIf Not IsEmpty(templateCell) Then
            targetCell.Value = templateCell.Value

        End If

    Next r

    ' ---- OPEN SOURCE FILE ----
    alreadyOpen = False
    For Each wb In Application.Workbooks
        If wb.Name = fileName Then
            alreadyOpen = True
            Set wbSource = wb
            Exit For
        End If
    Next wb

    If Not alreadyOpen Then
        Set wbSource = Workbooks.Open(fullPath, ReadOnly:=True, UpdateLinks:=False)
    End If

    ' ---- RECALCULATE ----
    Application.CalculateFull

    ' ---- CLOSE SOURCE FILE ----
    If Not alreadyOpen Then
        wbSource.Close SaveChanges:=False
    End If

    Application.ScreenUpdating = True
    Application.DisplayAlerts = True

    MsgBox "Done! Column " & userInput & " updated for: " & monthVal & "/" & yearVal, _
           vbInformation, "Refresh Complete"

End Sub
