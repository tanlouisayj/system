Sub RefreshHeadcountData()

    Dim wsProductivity As Worksheet
    Dim yearVal As String
    Dim monthVal As String
    Dim fileName As String
    Dim filePath As String
    Dim fullPath As String
    Dim wbSource As Workbook
    Dim monthCell As Range
    Dim chCol As Long
    
    ' ---- SETTINGS ----
    Set wsProductivity = ThisWorkbook.Sheets("Productivity")
    
    ' Get column number for CH
    chCol = wsProductivity.Range("CH18").Column
    
    ' Both year and month extracted from CH18
    Set monthCell = wsProductivity.Cells(18, chCol)  ' e.g. 01/03/2026
    
    ' Validate cell has a date
    If Not IsDate(monthCell.Value) Then
        MsgBox "CH18 does not contain a valid date. Please check.", vbExclamation, "Invalid Date"
        Exit Sub
    End If
    
    ' Build YYYYMM prefix from CH18
    yearVal = Format(monthCell.Value, "YYYY")   ' → "2026"
    monthVal = Format(monthCell.Value, "MM")    ' → "03"
    
    ' Build file name and path
    fileName = yearVal & monthVal & "_Regional IBG Staff Role Tagging.xlsx"
    filePath = "\\nassgdce1bvc1\IBG_Reg1&2_Vol1\IBG Reg 1&2\Qlikview\IBG Headcount\" & yearVal & "\"
    fullPath = filePath & fileName
    
    ' ---- CHECK FILE EXISTS ----
    If Dir(fullPath) = "" Then
        MsgBox "File not found: " & fullPath, vbExclamation, "File Missing"
        Exit Sub
    End If
    
    ' ---- OPEN SOURCE FILE ----
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    
    ' Check if already open
    Dim alreadyOpen As Boolean
    alreadyOpen = False
    Dim wb As Workbook
    For Each wb In Application.Workbooks
        If wb.Name = fileName Then
            alreadyOpen = True
            Set wbSource = wb
            Exit For
        End If
    Next wb
    
    ' Open if not already open
    If Not alreadyOpen Then
        Set wbSource = Workbooks.Open(fullPath, ReadOnly:=True, UpdateLinks:=False)
    End If
    
    ' ---- RECALCULATE ----
    Application.CalculateFull
    
    ' ---- CLOSE SOURCE FILE (if we opened it) ----
    If Not alreadyOpen Then
        wbSource.Close SaveChanges:=False
    End If
    
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    
    MsgBox "Done! Data refreshed for: " & yearVal & "/" & monthVal, vbInformation, "Refresh Complete"

End Sub
